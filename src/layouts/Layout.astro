---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Fleurs de Marché — L'Isle-sur-la-Sorgue, Salon, Pont-Saint-Esprit",
  description = "Fleuriste familial sur les marchés provençaux. Bouquets, compositions, mariages & événements."
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="keywords" content="fleuriste, marché, Provence, L'Isle-sur-la-Sorgue, Salon-de-Provence, bouquets, mariages" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lilita+One&family=Crimson+Pro:ital,wght@0,400;0,600;1,400;1,600&family=DM+Sans:wght@400;500;700&family=Courier+Prime&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <!-- ═══ NAVIGATION ═══ -->
    <header id="main-nav" class="fixed top-0 left-0 right-0 z-50 bg-vert-canard/95 backdrop-blur-md border-b-[3px] border-moutarde">
      <nav class="max-w-[1400px] mx-auto px-5 sm:px-10 py-4 flex items-center justify-between">
        <!-- Logo groovy -->
        <a href="/" class="font-heading text-[26px] text-creme hover:text-moutarde transition-colors duration-300">
          Fleurs de Marché
        </a>
        <!-- Burger mobile -->
        <button id="menu-toggle" class="md:hidden relative w-8 h-8 flex items-center justify-center z-50" aria-label="Menu">
          <div class="space-y-1.5" id="burger-lines">
            <span class="block w-7 h-[3px] bg-creme rounded-full transition-all duration-300 origin-center"></span>
            <span class="block w-5 h-[3px] bg-moutarde rounded-full transition-all duration-300"></span>
            <span class="block w-7 h-[3px] bg-creme rounded-full transition-all duration-300 origin-center"></span>
          </div>
        </button>
        <!-- Desktop nav -->
        <ul class="hidden md:flex items-center gap-9">
          <li><a href="/" class="font-body text-[15px] font-medium uppercase tracking-[1.5px] text-creme hover:text-moutarde transition-colors duration-300">Accueil</a></li>
          <li><a href="/marches" class="font-body text-[15px] font-medium uppercase tracking-[1.5px] text-creme hover:text-moutarde transition-colors duration-300">Marchés</a></li>
          <li><a href="/creations" class="font-body text-[15px] font-medium uppercase tracking-[1.5px] text-creme hover:text-moutarde transition-colors duration-300">Créations</a></li>
          <li><a href="/evenements" class="font-body text-[15px] font-medium uppercase tracking-[1.5px] text-creme hover:text-moutarde transition-colors duration-300">Événements</a></li>
          <li>
            <a href="/contact" class="font-body text-[14px] font-bold uppercase tracking-[1px] bg-moutarde text-charcoal px-5 py-2.5 rounded-full hover:bg-orange-vif transition-all duration-300 hover:scale-105">
              Contact
            </a>
          </li>
        </ul>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="fixed inset-0 bg-vert-canard z-40 flex flex-col items-center justify-center translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] md:hidden">
        <ul class="flex flex-col items-center gap-7">
          <li><a href="/" class="font-heading text-4xl text-creme hover:text-moutarde transition-colors">Accueil</a></li>
          <li><a href="/marches" class="font-heading text-4xl text-creme hover:text-moutarde transition-colors">Marchés</a></li>
          <li><a href="/creations" class="font-heading text-4xl text-creme hover:text-moutarde transition-colors">Créations</a></li>
          <li><a href="/evenements" class="font-heading text-4xl text-creme hover:text-moutarde transition-colors">Événements</a></li>
          <li><a href="/contact" class="font-heading text-4xl text-moutarde hover:text-orange-vif transition-colors">Contact</a></li>
        </ul>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <!-- ═══ FOOTER ═══ -->
    <footer class="bg-vert-canard relative overflow-hidden">
      <div class="grain absolute inset-0"></div>
      <!-- Rayure décorative top -->
      <div class="h-3 stripes-bg"></div>
      <div class="relative z-10 max-w-[1400px] mx-auto px-5 sm:px-10 py-16 md:py-20">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-6">
          <!-- Brand -->
          <div class="md:col-span-5">
            <h3 class="font-heading text-4xl text-creme mb-5">Fleurs de Marché</h3>
            <p class="font-body text-vert-sauge text-lg leading-relaxed max-w-sm">
              Une affaire de famille sur les marchés provençaux. Des fleurs fraîches, un savoir-faire artisanal, et beaucoup d'amour.
            </p>
          </div>
          <!-- Marchés -->
          <div class="md:col-span-4">
            <h4 class="font-accent text-[12px] uppercase tracking-[3px] text-moutarde mb-5">Retrouvez-nous</h4>
            <ul class="space-y-3">
              <li class="font-body text-[16px] text-vert-sauge">L'Isle-sur-la-Sorgue — <span class="text-creme font-medium">Dimanche</span></li>
              <li class="font-body text-[16px] text-vert-sauge">Salon-de-Provence — <span class="text-creme font-medium">Mercredi</span></li>
              <li class="font-body text-[16px] text-vert-sauge">Pont-Saint-Esprit — <span class="text-creme font-medium">Samedi</span></li>
            </ul>
          </div>
          <!-- Contact -->
          <div class="md:col-span-3">
            <h4 class="font-accent text-[12px] uppercase tracking-[3px] text-moutarde mb-5">Contact</h4>
            <ul class="space-y-3">
              <li><a href="tel:+33600000000" class="font-body text-[16px] text-vert-sauge hover:text-creme transition-colors">06 00 00 00 00</a></li>
              <li><a href="mailto:contact@fleursdemarch.fr" class="font-body text-[16px] text-vert-sauge hover:text-creme transition-colors">contact@fleursdemarch.fr</a></li>
            </ul>
          </div>
        </div>
        <div class="mt-14 pt-6 border-t border-creme/10 flex flex-col md:flex-row justify-between items-center gap-3">
          <p class="font-accent text-[11px] text-vert-sauge/50 uppercase tracking-[3px]">
            © {new Date().getFullYear()} Fleurs de Marché
          </p>
          <p class="font-accent text-[11px] text-vert-sauge/50 uppercase tracking-[3px]">
            Marchés provençaux depuis toujours
          </p>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const toggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const burgerLines = document.getElementById('burger-lines');
      let menuOpen = false;

      toggle?.addEventListener('click', () => {
        menuOpen = !menuOpen;
        if (menuOpen) {
          mobileMenu?.classList.remove('translate-x-full');
          mobileMenu?.classList.add('translate-x-0');
          burgerLines?.classList.add('menu-open');
        } else {
          mobileMenu?.classList.add('translate-x-full');
          mobileMenu?.classList.remove('translate-x-0');
          burgerLines?.classList.remove('menu-open');
        }
      });

      // Scroll reveal
      const reveals = document.querySelectorAll('.reveal, .reveal-scale');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12 });
      reveals.forEach(el => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .menu-open span:nth-child(1) {
    transform: rotate(45deg) translate(4px, 4px);
  }
  .menu-open span:nth-child(2) {
    opacity: 0;
    transform: translateX(10px);
  }
  .menu-open span:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -4px);
  }
</style>
